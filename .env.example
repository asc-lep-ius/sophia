# Auth: run `sophia auth login` to authenticate via browser (SSO)

# SECRET — never commit actual values
SOPHIA_GEMINI_API_KEY=          # optional: enables LLM topic extraction
# SECRET — never commit actual values
SOPHIA_GROQ_API_KEY=            # optional: LLM fallback provider
# SECRET — never commit actual values
SOPHIA_ANNAS_API_KEY=           # optional: Anna's Archive JSON API

# Configuration (not secrets — safe to commit)
# SOPHIA_DOWNLOAD_DIR=~/Downloads/sophia
# SOPHIA_MAX_DOWNLOAD_SIZE_BYTES=5368709120
# SOPHIA_GUI_PORT=8080
# GPU: use compose profile instead → make docker-gui-up-gpu
# GITHUB_TOKEN=                  # optional: higher GitHub API rate limits
